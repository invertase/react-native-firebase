+            if (this.ws && this.ws.readyState === Client.WebSocket.OPEN) {
+                if (typeof this.ws.ping === "function") {
+                    try {
+                        this.ws.ping();
+                    }
+                    catch (err) {
+                        console.warn(`[mocha-remote-ws] keepalive ping failed readyState=${readyState} err=${err?.message || err}`);
+                    }
+                }
+            }
+            else {
+                console.warn(`[mocha-remote-ws] keepalive skip readyState=${readyState}`);
+            }
+        }, 5000);
+    }
+    stopKeepalive() {
+        if (this._keepaliveTimer) {
+            clearInterval(this._keepaliveTimer);
+            this._keepaliveTimer = null;
+        }
+    }
+
 }
 
 Client.WebSocket = WebSocket;
