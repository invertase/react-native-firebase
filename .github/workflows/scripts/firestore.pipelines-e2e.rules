rules_version = '2';
// Security rules for the Enterprise pipelines-e2e database used by Pipeline.e2e.js.
// Intentionally permissive: shared cloud test database for RNFB CI and local Detox runs.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if database == "pipelines-e2e";
    }
  }
}
